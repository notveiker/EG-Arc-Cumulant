# ─────────────────────────────────────────────────────────────────────────────
# Cumulant — Arc testnet configuration (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────────────────────

# Chain
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER_URL=https://testnet.arcscan.app

# Canonical Arc testnet USDC (ERC-20 interface, 6 decimals). Native gas token.
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Deployer / resolver (server-owned admin key). Fund with USDC via faucet.circle.com.
DEPLOYER_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# Deployed Cumulant contracts (the deploy script writes contracts/deployments/<chainId>.json,
# which is the source of truth; these env overrides are optional)
PREDICTION_MARKET_ADDRESS=
BASKET_VAULT_ADDRESS=
TRANCHE_VAULT_ADDRESS=
PROTECTED_NOTE_ADDRESS=

# Which chain the backend/frontend target: "arc" or "local"
CUMULANT_CHAIN=local

# ── Local development (Anvil) ────────────────────────────────────────────────
# RPC for the local chain (defaults to http://127.0.0.1:8545).
LOCAL_RPC_URL=http://127.0.0.1:8545
# Resolver/owner key on local — defaults to Anvil account #0 if unset (the deploy-local deployer).
LOCAL_RESOLVER_PRIVATE_KEY=

# ── Backend server ───────────────────────────────────────────────────────────
BACKEND_PORT=13201
# Comma-separated CORS allowlist for the frontend origin(s); loopback is always allowed.
FRONTEND_URL=http://localhost:13200
# Bearer secret gating the server-signed resolver routes. Unset = open (local/dev only).
RESOLVER_API_SECRET=

# ── Polymarket proxy (REQUIRED from geo-blocked regions, e.g. the US) ─────────
# Polymarket's Gamma + CLOB APIs are geo-blocked — from a blocked region the
# connection is dropped (fetch fails, curl shows HTTP 000) and the basket/tranche/
# distribution feeds fall back to seeded data. Set this to route ONLY the
# Polymarket requests through a proxy / VPN exit in an allowed region; all other
# traffic (Arc RPC, yields) stays direct. Supports HTTP(S) and SOCKS proxies:
#   http://user:pass@host:port  |  socks5://user:pass@host:port
# (A whole-machine system VPN also works with NO config — just turn it on.)
POLYMARKET_PROXY_URL=

# RELAY mode — for restrictive networks (e.g. work wifi) that block VPN/Tor and
# odd proxy ports. Point at a plain HTTPS endpoint (reached over :443, so it
# passes corporate firewalls) that fetches {url} from a non-US region. Use a free
# scraping API with country=EU, or a self-hosted relay. Takes precedence over
# POLYMARKET_PROXY_URL. The target URL goes in the {url} placeholder.
#   ScraperAPI : https://api.scraperapi.com/?api_key=KEY&country_code=eu&url={url}
#   ScrapingAnt: https://api.scrapingant.com/v2/general?x-api-key=KEY&proxy_country=DE&browser=false&url={url}
#   self-host  : https://your-relay.vercel.app/?url={url}
POLYMARKET_RELAY_URL=

# Optional: explorer verification
ARCSCAN_API_KEY=

# ── Supabase (OPTIONAL — persistence for the History ledger / PPN vaults / NAV
#    snapshots). If UNSET, the backend runs fine in "on-chain + Polymarket only"
#    mode: positions read from chain, but the Portfolio → History tab won't
#    persist past transactions. To enable: create a Supabase project, run the SQL
#    in backend/src/db/*.sql, then set both vars below. ───────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Frontend (Next.js public env — set in frontend/.env.local) ────────────────
# NEXT_PUBLIC_BACKEND_URL=http://localhost:13201
# NEXT_PUBLIC_CHAIN=arc
# WalletConnect/Reown project id — REQUIRED for mobile-QR WalletConnect (free at
# cloud.reown.com). Injected wallets (MetaMask/Rainbow/Coinbase) work without it.
# NEXT_PUBLIC_WC_PROJECT_ID=
