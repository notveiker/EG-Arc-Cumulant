# Secrets
.env
.env.*
!.env.example
# .env.shared holds committed, non-secret team defaults (chain + Polymarket relay)
# so a fresh clone runs with zero local config. NEVER put private keys here.
!.env.shared
*.key

# Node
node_modules/
.next/
dist/
build/
*.log
.logs/
*.tsbuildinfo

# Backend runtime data (continuous-distribution pool + position store)
.distribution-pools.json
.distribution-positions.json

# Foundry
contracts/out/
contracts/cache/
contracts/broadcast/**/dry-run/
# Keep only run-latest.json; the timestamped broadcast logs are local churn.
contracts/broadcast/**/run-*.json
!contracts/broadcast/**/run-latest.json

# OS / editor
.DS_Store
.idea/
.vscode/

# ── Excluded from this public release ─────────────────────────────────────────
# Proprietary models / quant research — kept private, not for the public repo.
cumulant-correlation-models/
# Onchain deploy artifacts — regenerated per deployment and tied to a deployer
# key. Redeploy fresh under your own keys (see handoff notes), then update the
# address tables in README.md / contracts/DEPLOYMENT.md.
contracts/deployments/
contracts/broadcast/
