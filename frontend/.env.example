# ─────────────────────────────────────────────────────────────────────────────
# Cumulant frontend — copy to .env.local and fill in.
# NEXT_PUBLIC_* vars are inlined at BUILD time, so they must be set before
# `next build`, not just at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the Cumulant backend (Express). Local default is http://localhost:13201.
# In production set this to the deployed backend origin (e.g. https://api.cumulant.xyz).
NEXT_PUBLIC_BACKEND_URL=http://localhost:13201

# Which chain the wallet/landing target: "arc" (Arc testnet) or "local" (Anvil).
# Defaults to "arc" — the deployed testnet target. Baskets / tranches / notes are
# sourced from live Polymarket and don't need a chain; this only affects the
# Connect-Wallet network + the landing's on-chain stats.
NEXT_PUBLIC_CHAIN=arc

# WalletConnect / Reown project id — REQUIRED for the Connect Wallet modal to work.
# Free, ~2 min: create a project at https://cloud.reown.com and paste the id here.
# A placeholder still lets injected wallets (MetaMask extension) connect, but the
# WalletConnect (mobile QR) path will fail until this is a real id.
NEXT_PUBLIC_WC_PROJECT_ID=

# Dynamic environment ID — REQUIRED only if you use the Dynamic auth/embedded-wallet
# path (app/providers.dynamic.tsx). Public client-side value (safe to commit as a
# placeholder; the real id lives in .env.local). Get it from the Dynamic dashboard:
#   https://app.dynamic.xyz  →  Developers  →  SDK & API Keys  →  "Environment ID"
# Use a SANDBOX environment for hackathon/dev.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# "Fund from any chain" (Dynamic Flow) entry on product buy panels. Set to "true"
# to show the working "Fund from any chain →" button. The actual cross-chain
# settlement also needs Flow enabled in the Dynamic dashboard + a webhook pointed
# at <backend>/api/flow/webhook whose signing secret is set as DYNAMIC_WEBHOOK_SECRET
# in the backend .env (the webhook fail-closes the unlock until that's configured).
NEXT_PUBLIC_DYNAMIC_FLOW_ENABLED=true
